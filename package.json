{
  "name": "newlogin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "backend": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "frontend": "npm --prefix frontend start",
    "start": "npm run frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "android": "npm --prefix frontend run android",
    "ios": "npm --prefix frontend run ios",
    "web": "npm --prefix frontend run web",
    "lint": "npm --prefix frontend run lint",
    "reset-project": "npm --prefix frontend run reset-project"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  },
  "dependencies": {
    "expo": "^53.0.20"
  }
}
